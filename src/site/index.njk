---
layout: false
---
<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="color-scheme" content="dark">
  <title>layertwo.dev</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Roboto+Mono:wght@400;700&display=swap">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/pruger/tiny-brutalism-css/tiny-brutalism.css">
  <link rel="stylesheet" href="/styles.css">
  <script src="/terminal-banner.js"></script>
  <script src="/terminal.js"></script>
</head>
<body>
  <div class="terminal">
    <div class="terminal-titlebar">
      <div class="terminal-dots">
        <span class="dot dot-red"></span>
        <span class="dot dot-yellow"></span>
        <span class="dot dot-green"></span>
      </div>
      <div class="terminal-title">layertwo.dev</div>
    </div>
    <div class="terminal-body">

    <div class="banner">
      <div class="banner-last-login"></div>
<pre class="banner-ascii">  _                       _
 | | __ _ _   _  ___ _ __| |___      _____
 | |/ _` | | | |/ _ \ '__| __\ \ /\ / / _ \
 | | (_| | |_| |  __/ |  | |_ \ V  V / (_) |
 |_|\__,_|\__, |\___|_|   \__| \_/\_/ \___/
          |___/</pre>
      <div class="banner-sep">────────────────────────────────</div>
    </div>

    <div class="log out">type 'ls' to explore or 'help' for all commands</div>

    <div class="command-end"><span class="current-input"></span><span class="cursor">▌</span></div>

    </div><!-- terminal-body -->
  </div>

  <div hidden>
    <div class="log out" id="out-whoami">lucas messenger — security engineer @ aws</div>
    <div class="log out" id="out-about">Security engineer focused on detection engineering, telemetry, and automation. Currently at AWS building response tools and AI-powered tooling.</div>
    <div class="log about-block" id="out-experience">
      <div class="exp-list">
        <div class="exp-entry">
          <div class="exp-row"><span class="exp-org">AWS · Security Engineer, OpRes</span> <span class="exp-year">2025–present</span></div>
          <div class="exp-detail">Response automation · enrichment pipelines · MCP servers · AI tooling</div>
        </div>
        <div class="exp-entry">
          <div class="exp-row"><span class="exp-org">AWS · Security Engineer, Detection Engineering</span> <span class="exp-year">2021–2025</span></div>
          <div class="exp-detail">Threat detections for 1.6M network devices · Splunk · Athena · SOAR platform</div>
        </div>
        <div class="exp-entry">
          <div class="exp-row"><span class="exp-org">Cisco · Information Security Engineer, CSIRT</span> <span class="exp-year">2019–2021</span></div>
          <div class="exp-detail">Splunk infrastructure · network packet metadata · query optimization engine</div>
        </div>
        <div class="exp-entry">
          <div class="exp-row"><span class="exp-org">Tempered Networks · Support Engineer</span> <span class="exp-year">2016–2019</span></div>
          <div class="exp-detail">Network security appliances · cloud deployments · sustaining engineering</div>
        </div>
      </div>
    </div>
    <div class="log about-block" id="out-contact">
      <div class="contact-links">
        <a href="https://github.com/layertwo" target="_blank" rel="noopener">github</a>
        <a href="https://linkedin.com/in/lmessenger" target="_blank" rel="noopener">linkedin</a>
      </div>
    </div>
    <div class="log out" id="out-skills">python · aws · kubernetes · splunk · detection-engineering · fastmcp · smithy · cdk</div>
    <div class="log project-list" id="out-projects">
      {% for project in projects %}
      <div class="project-row">
        <a href="{{ project.url }}" class="project-name" target="_blank" rel="noopener">{{ project.name }}</a>
        <span class="project-desc">{{ project.description }}</span>
      </div>
      {% endfor %}
    </div>
  </div>
</body>
</html>
