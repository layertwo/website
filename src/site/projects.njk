---
title: Projects
layout: layout-wide.njk
---

<div class="row">
  {% for project in projects %}
  <div class="col col-4">
    <div class="box" style="display:flex;flex-direction:column;height:100%">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.5rem">
        <strong>{{ project.name }}</strong>
        <span style="border:1px solid;padding:2px 6px;font-size:0.8em">{{ project.language }}</span>
      </div>
      <p style="flex:1;font-size:0.875em">{{ project.description }}</p>
      <div style="margin-bottom:0.75rem">
        {% for tag in project.tags %}
        <span style="border:1px solid;padding:1px 5px;font-size:0.75em;margin-right:4px">{{ tag }}</span>
        {% endfor %}
      </div>
      <a href="{{ project.url }}" class="button" style="margin-top:auto">→ GitHub</a>
    </div>
  </div>
  {% endfor %}
</div>

<div style="margin-top:2rem;font-family:'Roboto Mono',monospace;font-size:0.9rem">
  <div><span style="color:#555">$ </span>ls about/</div>
  <div style="padding-left:1rem"><span style="color:#555">→ </span><a href="/about" style="text-decoration:underline;text-decoration-style:dashed">about</a></div>
</div>
